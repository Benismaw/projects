class Calc {
    int add(int a, int b) { return a + b; }
}
{
    Calc c = new Calc();
    // L'appel interne c.add(1, 2) doit être nettoyé avant l'appel externe
    println(c.add(c.add(1, 2), c.add(3, 4))); 
}
