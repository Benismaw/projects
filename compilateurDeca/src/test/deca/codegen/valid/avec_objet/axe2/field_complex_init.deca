class Calc {
    int x = (2 + 3) * 3;
    float y = 15.0 / 2.0;
    boolean b = (5 > 2) && (true || false);
}

{
    Calc c = new Calc();
    print(c.x, " ", c.y, " ");
    if (c.b) { print("true"); };
