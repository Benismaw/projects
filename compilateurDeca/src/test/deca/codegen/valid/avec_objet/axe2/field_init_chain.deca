// Description: Initialisation d'un champ dépendant d'un champ déjà déclaré.
// Resultats: 10 20 30
class A {
    int x = 10;
}
class B extends A {
    int y = x + 10; // Utilise le champ hérité
    int z = y + 10; // Utilise le champ de la même classe
}
{
    B b = new B();
    println(b.x, " ", b.y, " ", b.z);
}

