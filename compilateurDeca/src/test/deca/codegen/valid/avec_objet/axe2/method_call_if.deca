// Description:
//    Vérifie qu'une méthode renvoyant un boolean est correctement traitée comme une condition dans un if
// Resultats:
//    Success
// Historique:
//    cree le 14/01/2026
class Checker {
    boolean isValid(int x) {
        return x > 0;
    }
}
{
    Checker c = new Checker();
    if (c.isValid(10)) {
        println("Success");
    } else {
        println("Failure");
    }
}
