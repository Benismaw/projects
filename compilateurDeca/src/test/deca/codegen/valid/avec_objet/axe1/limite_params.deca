// Description:
//    Méthode avec 7 paramètres pour tester les offsets LB.
// Resultats:
//    28
// Historique: cree le 14/01/2026
class Sommeur {
    int somme(int a, int b, int c, int d, int e, int f, int g) {
        return a + b + c + d + e + f + g;
    }
}
{
    Sommeur s = new Sommeur();
    println(s.somme(1, 2, 3, 4, 5, 6, 7)); // Doit afficher 28
}
