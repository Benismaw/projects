// Description:
//    Test des priorités logiques (AND prioritaire sur OR).
// Resultats:
//    Test 1: OK
//    Test 2: OK
{
    // false || true && false  => false || (true && false) => false
    if (false || true && false) {
        println("Test 1: KO");
    } else {
        println("Test 1: OK");
    }

    // (false || true) && true => true && true => true
    if ((false || true) && true) {
        println("Test 2: OK");
    } else {
        println("Test 2: KO");
    }
}
