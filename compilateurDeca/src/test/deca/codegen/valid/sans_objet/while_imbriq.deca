// Description:
//    Boucles While imbriquées avec conditions changeantes.
// Resultats:
//    11
//    12
//    21
//    22
{
    int i = 1;
    int j = 1;
    while (i <= 2) {
        j = 1;
        while (j <= 2) {
            println(i, j);
            j = j + 1;
        }
        i = i + 1;
    }
}
