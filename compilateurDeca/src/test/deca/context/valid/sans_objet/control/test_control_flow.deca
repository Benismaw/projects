{
    int x = 0;
    
    if (true) {
        x = 1;
    }

    if (false) {
        x = 2;
    } else {
        x = 3;
    }

    if (x == 1) {
        x = 4;
    } else if (x == 2) {
        x = 5;
    } else {
        x = 6;
    }

    while (x < 10) {
        x = x + 1;
    }
}
